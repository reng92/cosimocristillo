---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import { getCollection, getEntry } from 'astro:content';
export const prerender = true;

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map(post => ({ params: { slug: post.slug } }));
}

const { slug } = Astro.params;
const post = await getEntry('blog', slug as string);
if (!post) return Astro.redirect('/blog');

const { Content } = await post.render();

function fmtDate(d: Date) {
  return new Intl.DateTimeFormat('it-IT', { day: 'numeric', month: 'long', year: 'numeric' }).format(new Date(d));
}
---
<Layout
  title={`${post.data.titolo} – Portico in Comune`}
  description={post.data.anteprima ?? post.data.titolo}
  ogImage={post.data.immagine}
>

<Header />

{post.data.immagine && (
  <div style="width:100%;max-height:420px;overflow:hidden">
    <img src={post.data.immagine} alt={post.data.titolo} style="width:100%;height:420px;object-fit:cover;display:block"/>
  </div>
)}

<div class="page-content">
  <a class="back-link" href="/blog">← Tutti gli articoli</a>
  <span class="tag">{fmtDate(post.data.data)}</span>
  <h1 style="font-size:clamp(1.6rem,4vw,2.5rem);font-weight:900;color:var(--blu);margin:.75rem 0 2rem;line-height:1.2">{post.data.titolo}</h1>
  <div class="prose">
    <Content />
  </div>

  {post.data.fotografie && post.data.fotografie.length > 0 && (
    <div style="margin-top:3rem">
      <h2 style="font-size:1.1rem;font-weight:800;color:var(--blu);margin-bottom:1.25rem">&#128247; Galleria foto</h2>
      <div class="galleria-grid" style="grid-template-columns:repeat(auto-fill,minmax(180px,1fr))">
        {post.data.fotografie.map((src, i) => (
          <a class="galleria-item glightbox" href={src} data-gallery="blog-gallery" data-title={`${post.data.titolo} – ${i + 1}`}>
            <img src={src} alt={`Foto ${i + 1}`} loading="lazy"/>
          </a>
        ))}
      </div>
    </div>
  )}

  <div style="margin-top:3rem;padding-top:2rem;border-top:1px solid var(--grigio2)">
    <a class="back-link" href="/blog">← Torna al blog</a>
  </div>
</div>

<footer style="background:var(--blu-s);color:rgba(255,255,255,.48);text-align:center;padding:2rem 1.5rem;font-size:.82rem">
  <a href="/" style="color:var(--oro);text-decoration:none">← Torna alla home</a>
</footer>

</Layout>
