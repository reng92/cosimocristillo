---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import { getCollection } from 'astro:content';
export const prerender = true;

const posts = (await getCollection('blog'))
  .sort((a, b) => b.data.data.valueOf() - a.data.data.valueOf());

function fmtDate(d: Date) {
  return new Intl.DateTimeFormat('it-IT', { day: 'numeric', month: 'long', year: 'numeric' }).format(new Date(d));
}
---
<Layout title="Blog – Portico in Comune" description="Diario di campagna di Cosimo Cristillo e Portico in Comune. Aggiornamenti, iniziative e notizie dall'amministrazione.">

<Header />

<div class="page-hero">
  <h1>&#128203; Diario di campagna</h1>
  <p>Aggiornamenti, proposte e novità da Portico in Comune</p>
</div>

<div class="page-content" style="max-width:1100px">
  {posts.length === 0
    ? <div class="empty-state" style="text-align:center;padding:4rem;color:var(--testo2)">
        <p style="font-size:1.1rem">&#128203; Nessun articolo ancora.<br/>I contenuti verranno pubblicati qui.</p>
      </div>
    : <div class="blog-grid">
        {posts.map(post => (
          <a class="blog-card" href={`/blog/${post.slug}`}>
            {post.data.immagine
              ? <img class="blog-card-img" src={post.data.immagine} alt={post.data.titolo} loading="lazy"/>
              : <div class="blog-card-img-placeholder">&#128203;</div>
            }
            <div class="blog-card-body">
              <span class="blog-card-date">{fmtDate(post.data.data)}</span>
              <h2 class="blog-card-title">{post.data.titolo}</h2>
              {post.data.anteprima && <p class="blog-card-excerpt">{post.data.anteprima}</p>}
              <span class="blog-card-link">Leggi tutto →</span>
            </div>
          </a>
        ))}
      </div>
  }
</div>

<footer style="background:var(--blu-s);color:rgba(255,255,255,.48);text-align:center;padding:2rem 1.5rem;font-size:.82rem">
  <a href="/" style="color:var(--oro);text-decoration:none">← Torna alla home</a>
</footer>

</Layout>
