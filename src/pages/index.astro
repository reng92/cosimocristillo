---
import Layout from '../layouts/Layout.astro';
import Countdown from '../components/Countdown.astro';
import Mappa from '../components/Mappa.astro';
import FacebookEmbed from '../components/FacebookEmbed.astro';
import { getCollection } from 'astro:content';

export const prerender = true;

const posts = (await getCollection('blog'))
  .sort((a, b) => b.data.data.valueOf() - a.data.data.valueOf())
  .slice(0, 3);

const ora = new Date();
const eventiProssimi = (await getCollection('eventi'))
  .filter(e => new Date(e.data.data) >= ora)
  .sort((a, b) => new Date(a.data.data).valueOf() - new Date(b.data.data).valueOf())
  .slice(0, 5);

const gallerie = (await getCollection('galleria'))
  .sort((a, b) => new Date(b.data.data).valueOf() - new Date(a.data.data).valueOf())
  .slice(0, 6);

function fmtDate(d: Date) {
  return new Intl.DateTimeFormat('it-IT', { day: 'numeric', month: 'long', year: 'numeric' }).format(new Date(d));
}
function fmtDay(d: Date)  { return new Intl.DateTimeFormat('it-IT', { day: 'numeric' }).format(new Date(d)); }
function fmtMon(d: Date)  { return new Intl.DateTimeFormat('it-IT', { month: 'short' }).format(new Date(d)); }
---

<Layout>

<!-- HEADER -->
<header>
  <div class="nav-inner">
    <a class="nav-brand" href="#top">
      <img class="nav-logo" src="/content/Logo%20Portico%20in%20Comune/LogoPorticoinComune.jpg" alt="Portico in Comune"/>
      <div class="nav-brand-text">
        <strong>Cosimo Cristillo</strong>
        <span>Portico in Comune</span>
      </div>
    </a>
    <nav>
      <a href="#intro">Il Progetto</a>
      <a href="#giorni">100 Giorni</a>
      <a href="#candidati">La Squadra</a>
      <a href="#comune">Programma</a>
      <a href="/blog">Blog</a>
      <a href="/eventi">Eventi</a>
      <a href="#voto" class="nav-cta">Vota</a>
    </nav>
  </div>
</header>

<!-- HERO -->
<section class="hero" id="top">
  <div class="hero-bg"></div>
  <video class="hero-bg-video" autoplay muted loop playsinline>
    <source src="/content/video.mp4" type="video/mp4"/>
  </video>
  <div class="hero-inner">
    <div class="hero-text">
      <div class="hero-top">
        <img src="/content/Logo%20Portico%20in%20Comune/LOGO%20%20PORTICO%20in%20COMUNE%20web.png" alt="Portico in Comune"/>
        <span class="hero-lista">Lista Civica &middot; Portico in Comune</span>
      </div>
      <h1 class="hero-nome">Cosimo<span>Cristillo</span></h1>
      <p class="hero-ruolo">Candidato Sindaco &middot; Portico di Caserta</p>
      <p class="hero-slogan">Facciamo<br><em>funzionare</em><br>le cose.</p>
      <div class="hero-meta">
        <span>&#128197; 24 e 25 Maggio 2026</span>
        <span>&#127963; Elezioni Comunali di Portico di Caserta</span>
      </div>
      <Countdown />
    </div>
    <div class="hero-video-wrap">
      <video class="hero-video" autoplay muted loop playsinline>
        <source src="/content/video.mp4" type="video/mp4"/>
      </video>
    </div>
  </div>
  <div class="hero-wave">
    <svg viewBox="0 0 1440 70" xmlns="http://www.w3.org/2000/svg" preserveAspectRatio="none">
      <path d="M0,45 C480,90 960,0 1440,45 L1440,70 L0,70 Z" fill="#ffffff"/>
    </svg>
  </div>
</section>

<!-- INTRO -->
<section class="sec" id="intro">
  <div class="container">
    <div class="prog-grid">
      <div>
        <img src="/content/Foto%20Cosimo%20Cristillo%20Sindaco/CosimoCristillo.jpg" alt="Cosimo Cristillo" style="width:100%;border-radius:1.25rem;box-shadow:0 12px 48px rgba(26,86,196,.14);display:block"/>
      </div>
      <div class="prog-body">
        <span class="tag">Il nostro impegno</span>
        <h2 class="stitle">Portico deve<br><span>ripartire.</span></h2>
        <div class="bar"></div>
        <p>Non è uno slogan, è una necessità che tutti vediamo ogni giorno. Negli ultimi anni il paese ha rallentato, ha perso occasioni, ha smesso di crescere come poteva. Strade, servizi, spazi pubblici: troppe cose sono rimaste ferme. E quando un paese si ferma, non perde solo tempo. Perde fiducia.</p>
        <div class="qblock">«Non parole, ma scelte. Il punto non è più raccontare cosa si farà, ma iniziare a farlo davvero.»</div>
        <p>Portico ha energie, ha persone, ha una comunità che chiede di essere ascoltata e rispettata nei fatti. La priorità è rimettere il Comune in funzione: valorizzare chi già lavora all'interno, rafforzare la struttura, rendere gli uffici più efficienti.</p>
        <p>A questo impegno diamo subito una forma concreta: un elenco chiaro di interventi nei <strong>primi cento giorni</strong>. Non un annuncio, ma un atto di responsabilità con obiettivi definiti e tempi verificabili.</p>
      </div>
    </div>
  </div>
</section>

<!-- BLOG PREVIEW -->
{posts.length > 0 && (
<section class="sec" id="blog-preview">
  <div class="container">
    <span class="tag">Diario di campagna</span>
    <h2 class="stitle">Ultime <span>novità</span></h2>
    <div class="bar"></div>
    <div class="blog-grid">
      {posts.map(post => (
        <a class="blog-card" href={`/blog/${post.slug}`}>
          {post.data.immagine
            ? <img class="blog-card-img" src={post.data.immagine} alt={post.data.titolo} loading="lazy"/>
            : <div class="blog-card-img-placeholder">&#128203;</div>
          }
          <div class="blog-card-body">
            <span class="blog-card-date">{fmtDate(post.data.data)}</span>
            <h3 class="blog-card-title">{post.data.titolo}</h3>
            {post.data.anteprima && <p class="blog-card-excerpt">{post.data.anteprima}</p>}
            <span class="blog-card-link">Leggi tutto →</span>
          </div>
        </a>
      ))}
    </div>
    <div style="text-align:center;margin-top:2rem">
      <a href="/blog" style="display:inline-flex;align-items:center;gap:.5rem;background:var(--blu);color:#fff;font-size:.85rem;font-weight:700;padding:.75rem 2rem;border-radius:100px;text-decoration:none">
        Tutti gli articoli →
      </a>
    </div>
  </div>
</section>
)}

<!-- I PRIMI 100 GIORNI -->
<section class="sec" id="giorni">
  <div class="container">
    <span class="tag light">Piano operativo</span>
    <h2 class="stitle on-dark">I Primi <span>100 Giorni</span></h2>
    <div class="bar"></div>
    <p class="lead light">Un metodo di amministrazione basato su priorità definite, atti concreti e tempi verificabili. Quattro direzioni chiare dentro cui si collocano tutte le scelte iniziali.</p>
    <div class="giorni-grid">
      <div class="gcol">
        <h3>1. Il Comune riparte</h3>
        <ul>
          <li>Canale WhatsApp istituzionale</li>
          <li>Punto Digitale per i cittadini</li>
          <li>Attivazione Punto Donna</li>
          <li>Attivazione Sportello Disabili</li>
          <li>Aula consiliare digitale e streaming</li>
        </ul>
      </div>
      <div class="gcol">
        <h3>2. Diciamo la verità</h3>
        <ul>
          <li>Operazione verità scuola Principe di Piemonte</li>
          <li>Verifica e attivazione asilo nido via Collodi</li>
          <li>Cronoprogramma lavori scuola pubblico</li>
          <li>Mappatura cantieri e opere incompiute</li>
        </ul>
      </div>
      <div class="gcol">
        <h3>3. Riapriamo i luoghi</h3>
        <ul>
          <li>Riapertura Piazza Berlinguer</li>
          <li>Attivazione Centro Polifunzionale</li>
          <li>Avvio restyling zona industriale</li>
          <li>Avvio completamento Teatro Comunale</li>
          <li>Riapertura Campo Sportivo</li>
        </ul>
      </div>
      <div class="gcol">
        <h3>4. Le persone al centro</h3>
        <ul>
          <li>Forum dei Giovani</li>
          <li>Consiglio Comunale dei Ragazzi</li>
          <li>Cartellone estivo &ldquo;Portico C&rsquo;&eacute;&rdquo;</li>
          <li>Riapertura Circolo Anziani in piazza</li>
          <li>Spazio anziani a Musicile</li>
          <li>Consulta delle associazioni</li>
          <li>Consulta commercianti e artigiani</li>
          <li>Programma culturale annuale</li>
          <li>Progetto Nonni Civici</li>
        </ul>
      </div>
      <div class="gcol">
        <h3>5. Sicurezza e decoro</h3>
        <ul>
          <li>Piano manutenzione strade</li>
          <li>Restyling plessi scolastici</li>
          <li>Pulizia caditoie</li>
          <li>Verifica sistema idrico</li>
          <li>Attivazione videosorveglianza</li>
          <li>Interventi rete fognaria</li>
        </ul>
      </div>
    </div>
  </div>
</section>

<!-- CANDIDATI -->
<section class="sec" id="candidati">
  <div class="container">
    <span class="tag">La squadra</span>
    <h2 class="stitle">Lista <span>Portico in Comune</span></h2>
    <div class="bar"></div>
    <p class="lead">Dodici consiglieri candidati insieme a Cosimo Cristillo. Persone diverse, con esperienze e competenze, unite da una scelta semplice: metterci la faccia per Portico.</p>
    <img class="tutti-banner" src="/content/tutti.jpg" alt="Tutta la squadra – Portico in Comune con Cosimo Cristillo Sindaco"/>
    <div class="cand-grid">
      <div class="cand-card sindaco">
        <img class="cand-photo" src="/content/Foto%20Cosimo%20Cristillo%20Sindaco/CosimoCristillo.jpg" alt="Cosimo Cristillo Sindaco"/>
        <div class="cand-info">
          <span class="sbadge">Candidato Sindaco</span>
          <div class="fn">Cosimo</div>
          <div class="ln">Cristillo</div>
        </div>
      </div>
      <div class="cand-card"><img class="cand-photo" src="/content/Foto%20candidati/LuigiBellopede.jpg" alt="Luigi Bellopede"/><div class="cand-info"><div class="fn">Luigi</div><div class="ln">Bellopede</div><div class="num">n&deg; 1 &middot; Giggino</div></div></div>
      <div class="cand-card"><img class="cand-photo" src="/content/Foto%20candidati/GiuseppeCicala.jpg" alt="Giuseppe Cicala"/><div class="cand-info"><div class="fn">Giuseppe</div><div class="ln">Cicala</div><div class="num">n&deg; 2 &middot; Peppe</div></div></div>
      <div class="cand-card"><img class="cand-photo" src="/content/Foto%20candidati/ConcettaFalcone.jpg" alt="Concetta Falcone"/><div class="cand-info"><div class="fn">Concetta</div><div class="ln">Falcone</div><div class="num">n&deg; 3</div></div></div>
      <div class="cand-card"><img class="cand-photo" src="/content/Foto%20candidati/GiovanniIodice.jpg" alt="Giovanni Iodice"/><div class="cand-info"><div class="fn">Giovanni</div><div class="ln">Iodice</div><div class="num">n&deg; 4 &middot; Gianni</div></div></div>
      <div class="cand-card"><img class="cand-photo" src="/content/Foto%20candidati/AntonioMassaro.jpg" alt="Antonio Massaro"/><div class="cand-info"><div class="fn">Antonio</div><div class="ln">Massaro</div><div class="num">n&deg; 5</div></div></div>
      <div class="cand-card"><img class="cand-photo" src="/content/Foto%20candidati/GerardoMassaro.jpg" alt="Gerardo Massaro"/><div class="cand-info"><div class="fn">Gerardo</div><div class="ln">Massaro</div><div class="num">n&deg; 6</div></div></div>
      <div class="cand-card"><img class="cand-photo" src="/content/Foto%20candidati/ElisabettaMerola.jpg" alt="Elisabetta Merola"/><div class="cand-info"><div class="fn">Elisabetta</div><div class="ln">Merola</div><div class="num">n&deg; 7 &middot; Lisa</div></div></div>
      <div class="cand-card"><img class="cand-photo" src="/content/Foto%20candidati/GiusyMerola.jpg" alt="Giusy Merola"/><div class="cand-info"><div class="fn">Giusy</div><div class="ln">Merola</div><div class="num">n&deg; 8 &middot; Giusi</div></div></div>
      <div class="cand-card"><img class="cand-photo" src="/content/Foto%20candidati/PatriziaMorrone.jpg" alt="Patrizia Morrone"/><div class="cand-info"><div class="fn">Patrizia</div><div class="ln">Morrone</div><div class="num">n&deg; 9</div></div></div>
      <div class="cand-card"><img class="cand-photo" src="/content/Foto%20candidati/GiuseppePascarella.jpg" alt="Giuseppe Pascarella"/><div class="cand-info"><div class="fn">Giuseppe</div><div class="ln">Pascarella</div><div class="num">n&deg; 10 &middot; Maresciallo</div></div></div>
      <div class="cand-card"><img class="cand-photo" src="/content/Foto%20candidati/LuigiPiccirillo.jpg" alt="Luigi Piccirillo"/><div class="cand-info"><div class="fn">Luigi</div><div class="ln">Piccirillo</div><div class="num">n&deg; 11</div></div></div>
      <div class="cand-card"><img class="cand-photo" src="/content/Foto%20candidati/MariaPiccirillo.jpg" alt="Maria Piccirillo"/><div class="cand-info"><div class="fn">Maria</div><div class="ln">Piccirillo</div><div class="num">n&deg; 12</div></div></div>
    </div>
  </div>
</section>

<!-- MAPPA -->
<section class="sec" id="mappa">
  <div class="container">
    <span class="tag">Il territorio</span>
    <h2 class="stitle">Portico sui <span>punti chiave</span></h2>
    <div class="bar"></div>
    <p class="lead">Le aree del paese al centro del programma: luoghi da riqualificare, opere da sbloccare, servizi da attivare.</p>
    <Mappa />
  </div>
</section>

<!-- PILASTRI NAV -->
<section class="sec-sm" id="pilastri">
  <div class="container">
    <div class="pilastri-grid">
      <a class="pilastro" href="#comune">
        <span class="pi">&#9881;&#65039;</span>
        <h3>Un Comune che funziona</h3>
        <p>Servizi digitali, sportelli dedicati, trasparenza e risposta ai cittadini</p>
      </a>
      <a class="pilastro" href="#vita">
        <span class="pi">&#127963;</span>
        <h3>Ridare vita a Portico</h3>
        <p>Piazze, scuola, giovani, anziani, commercio e cultura locale</p>
      </a>
      <a class="pilastro" href="#opere">
        <span class="pi">&#128296;</span>
        <h3>Sbloccare le opere</h3>
        <p>Cantieri fermi, teatro, strade, zona industriale e PUC</p>
      </a>
      <a class="pilastro" href="#giorni">
        <span class="pi">&#128203;</span>
        <h3>I Primi 100 Giorni</h3>
        <p>Piano operativo con obiettivi definiti e tempi verificabili</p>
      </a>
    </div>
  </div>
</section>

<!-- UN COMUNE CHE FUNZIONA -->
<section class="sec" id="comune">
  <div class="container">
    <span class="tag">Pilastro 1</span>
    <h2 class="stitle">Un Comune che <span>funziona</span></h2>
    <div class="bar"></div>
    <p class="lead">Far funzionare il Comune è il primo vero atto politico. Senza un'amministrazione che lavora e risponde, nessun progetto può reggere nel tempo.</p>
    <div class="prog-grid">
      <div class="prog-body">
        <p>La macchina comunale ha bisogno di essere rafforzata. Pochi dipendenti, un'organizzazione fragile, servizi che faticano a stare al passo. L'obiettivo è rimettere il Comune nelle condizioni di funzionare davvero.</p>
        <p>Il <strong>potenziamento dei servizi digitali</strong> sarà centrale: SPID, Carta d'Identità Elettronica, richieste online. Ma senza lasciare indietro nessuno: rafforzeremo gli sportelli fisici in collaborazione con CAF e patronati del territorio.</p>
        <p>Attiveremo un <strong>canale WhatsApp istituzionale</strong> per segnalare problemi in tempo reale e ricevere aggiornamenti. Costruiremo un <strong>Comune più giusto</strong>: pagamenti flessibili, rateizzazioni chiare, regolarizzazione spontanea dei tributi.</p>
        <p>Istituiremo uno <strong>Sportello Sociale</strong> per mappare i bisogni reali, uno <strong>Sportello Disabili</strong> come punto stabile di ascolto per le famiglie, e un <strong>Punto Donna</strong> come spazio sicuro di orientamento e tutela.</p>
      </div>
      <div class="prog-box">
        <h4>Interventi concreti</h4>
        <ul>
          <li>Digitalizzazione servizi con SPID e CIE</li>
          <li>Canale WhatsApp istituzionale attivo</li>
          <li>Punto Digitale per assistere i cittadini</li>
          <li>Sportello Sociale – mappatura bisogni</li>
          <li>Sportello Disabili – ascolto e orientamento</li>
          <li>Punto Donna – spazio sicuro e accessibile</li>
          <li>Ufficio legale e riduzione contenziosi</li>
          <li>Pagamento tributi flessibile con rateizzazioni</li>
          <li>Collaborazione con CAF e patronati</li>
          <li>Aula consiliare digitale e streaming live</li>
        </ul>
      </div>
    </div>
  </div>
</section>

<!-- RIDARE VITA A PORTICO -->
<section class="sec" id="vita" style="background:var(--grigio)">
  <div class="container">
    <span class="tag">Pilastro 2</span>
    <h2 class="stitle">Ridare vita a <span>Portico</span></h2>
    <div class="bar"></div>
    <p class="lead">Un paese vive quando i suoi spazi, le sue energie e le sue relazioni tornano a muoversi. Il decoro urbano è il primo segnale di rispetto verso i cittadini.</p>
    <div class="prog-grid flip">
      <div class="prog-box">
        <h4>Spazi, persone e comunità</h4>
        <ul>
          <li>Riapertura Piazza Berlinguer alla comunità</li>
          <li>Riqualificazione e valorizzazione Piazza degli Artisti</li>
          <li>Sostegno attività di Piazza Rimembranza</li>
          <li>Riapertura Campo Sportivo</li>
          <li>Polisportiva e rete sportiva multidisciplina</li>
          <li>Forum dei Giovani – spazio reale di partecipazione</li>
          <li>Consiglio Comunale dei Ragazzi</li>
          <li>Programma UNICEF – Città Amica dei Bambini</li>
          <li>Circolo Anziani riaperto in Piazza Rimembranza</li>
          <li>Bocciodromo e spazio anziani a Musicile</li>
          <li>Progetto Nonni Civici – tutela aree verdi</li>
          <li>Assistenza domiciliare e consegna medicinali</li>
          <li>Mesi di prevenzione sanitaria gratuita</li>
          <li>Consulta permanente commercianti e artigiani</li>
          <li>Area mercato attrezzata e fiera settimanale</li>
          <li>Nuovo bando raccolta rifiuti efficiente</li>
          <li>Piano traffico condiviso con i cittadini</li>
          <li>Baratto amministrativo per beni comuni</li>
          <li>Interventi nelle aree di Musicile e via Mazzini</li>
        </ul>
      </div>
      <div class="prog-body">
        <p>Portico ha troppe aree abbandonate, troppi luoghi che potrebbero essere vissuti e non lo sono. Vogliamo <strong>ripartire dai luoghi</strong>: dal loro recupero, dalla loro cura e dalla loro funzione.</p>
        <p>Le piazze devono tornare a essere il cuore della comunità. <strong>Piazza Berlinguer</strong> va riaperta e restituita, <strong>Piazza degli Artisti</strong> riqualificata, <strong>Piazza Rimembranza</strong> sostenuta con iniziative concrete che riportino vita nel centro del paese.</p>
        <p>Ridare vita a Portico significa soprattutto investire sui <strong>giovani</strong>: Forum dei Giovani, Consiglio dei Ragazzi, luoghi di aggregazione, sport, adozione del programma UNICEF. E allo stesso tempo riconoscere il ruolo degli <strong>anziani</strong>, valorizzandone l'esperienza attraverso i Nonni Civici.</p>
        <p>Il commercio locale merita supporto: una <strong>Consulta permanente</strong>, un'area mercato organizzata, una fiera settimanale degna di questo nome. Perché ridare vita a Portico significa rimettere in movimento spazi, attività e relazioni.</p>
      </div>
    </div>
  </div>
</section>

<!-- SCUOLA E CULTURA -->
<section class="sec" id="scuola">
  <div class="container">
    <span class="tag">Scuola e Cultura</span>
    <h2 class="stitle">La scuola: una priorità <span>non rinviabile</span></h2>
    <div class="bar"></div>
    <p class="lead">La scuola di via Principe di Piemonte è il simbolo più evidente di un fallimento. Un edificio abbattuto e, dopo anni, ancora un cantiere aperto. Su questo non ci saranno più ritardi, né giustificazioni.</p>
    <div class="prog-grid">
      <div class="prog-body">
        <p><strong>La prima cosa sarà un'operazione verità.</strong> I cittadini hanno il diritto di sapere cosa è successo, perché i lavori sono fermi e di chi sono le responsabilità. Poi tempi certi con un cronoprogramma pubblico e verificabile.</p>
        <p>Avvieremo un piano immediato di <strong>riqualificazione degli edifici scolastici</strong>: scuola media di via Trento, plessi dell'infanzia di via Collodi, strutture di Musicile. Non solo manutenzione, ma restituire dignità agli spazi in cui crescono i nostri ragazzi.</p>
        <p>Attiveremo finalmente l'<strong>asilo nido di via Collodi</strong>, inaugurato ma mai realmente aperto. Un servizio fondamentale per le famiglie non può restare inutilizzato.</p>
        <p>Sul fronte <strong>culturale</strong>: sosterremo l'archivio digitale dei Canti di Sant'Antuono, costruiremo un programma annuale attorno alla Festa di Sant'Antonio Abate, istituiremo la Consulta delle associazioni e realizzeremo una <strong>biblioteca comunale</strong> con sale lettura e spazi studio.</p>
      </div>
      <div class="prog-box" style="background:var(--grigio)">
        <h4>Scuola e cultura</h4>
        <ul>
          <li>Operazione verità – scuola via Principe di Piemonte</li>
          <li>Cronoprogramma lavori pubblico e verificabile</li>
          <li>Restyling urgente scuola media via Trento</li>
          <li>Riqualificazione plessi infanzia via Collodi</li>
          <li>Riqualificazione strutture scolastiche Musicile</li>
          <li>Attivazione asilo nido via Collodi</li>
          <li>Contrasto al bullismo e disagio giovanile</li>
          <li>Archivio digitale Canti di Sant'Antuono (Pro Loco)</li>
          <li>Programma annuale Festa Sant'Antonio Abate</li>
          <li>Biblioteca comunale con sale studio</li>
          <li>Consulta delle associazioni culturali</li>
          <li>Calendario culturale annuale condiviso</li>
        </ul>
      </div>
    </div>
  </div>
</section>

<!-- SBLOCCARE LE OPERE -->
<section class="sec sec-dark" id="opere">
  <div class="container">
    <span class="tag light">Pilastro 3</span>
    <h2 class="stitle on-dark">Sbloccare le opere,<br><span>costruire il futuro</span></h2>
    <div class="bar"></div>
    <p class="lead light">Portico oggi è ferma. Cantieri aperti da anni, opere incompiute, interventi mai conclusi. La priorità è chiudere ciò che è rimasto aperto troppo a lungo.</p>
    <div class="prog-grid">
      <div class="prog-body">
        <p>Non è più accettabile che il <strong>Teatro Comunale</strong> resti incompiuto. Deve essere completato e diventare il centro della vita culturale di Portico: uno spazio vivo, aperto, capace di ospitare eventi e formazione.</p>
        <p>Le strade sono in condizioni inaccettabili. Interverremo con un <strong>piano di manutenzione e decoro urbano</strong> con cronoprogramma chiaro e verificabile. Gli allagamenti non possono più essere considerati un problema ciclico: il <strong>sistema fognario</strong> sarà affrontato in modo definitivo.</p>
        <p>Il <strong>Piano Urbanistico Comunale</strong> tornerà a essere uno strumento dell'amministrazione, non solo tecnico ma politico: programmazione dello sviluppo urbano, tutela del territorio, condizioni certe per cittadini e imprese.</p>
        <p>La <strong>Zona Industriale</strong> sarà potenziata con servizi, sicurezza e viabilità. Il <strong>Centro Polifunzionale</strong> diventerà il cuore dello sviluppo: Agenzia Giovani, Sportello Imprese, formazione, inserimento lavorativo.</p>
      </div>
      <div class="prog-box dark">
        <h4>Opere e infrastrutture</h4>
        <ul>
          <li>Completamento Teatro Comunale</li>
          <li>Piano manutenzione strade con cronoprogramma</li>
          <li>Risoluzione definitiva sistema fognario</li>
          <li>Riapertura Campo Sportivo nel più breve tempo</li>
          <li>Piano Urbanistico Comunale aggiornato</li>
          <li>Miglioramento illuminazione pubblica</li>
          <li>Viabilità e segnaletica zona industriale</li>
          <li>Videosorveglianza sul territorio</li>
          <li>Centro Polifunzionale – Agenzia Giovani</li>
          <li>Sportello Imprese (finanziamenti, bandi)</li>
          <li>Sala convegni e spazi formazione</li>
          <li>Collegamento sviluppo economico e formazione</li>
          <li>Riqualificazione aree Musicile e via Mazzini</li>
          <li>Baratto amministrativo per beni comuni</li>
        </ul>
      </div>
    </div>
  </div>
</section>

