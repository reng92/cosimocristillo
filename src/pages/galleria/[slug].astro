---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { getCollection, getEntry } from 'astro:content';
export const prerender = true;

export async function getStaticPaths() {
  const gallerie = await getCollection('galleria');
  return gallerie.map(a => ({ params: { slug: a.slug } }));
}

const { slug } = Astro.params;
const album = await getEntry('galleria', slug as string);
if (!album) return Astro.redirect('/galleria');

function fmtDate(d: Date) {
  return new Intl.DateTimeFormat('it-IT', { day: 'numeric', month: 'long', year: 'numeric' }).format(new Date(d));
}
---
<Layout title={`${album.data.titolo} – Galleria Portico in Comune`}>

<Header />

<div class="page-content" style="max-width:1100px">
  <a class="back-link" href="/galleria">← Tutti gli album</a>
  <span class="tag">{fmtDate(album.data.data)}</span>
  <h1 style="font-size:clamp(1.5rem,3vw,2.25rem);font-weight:900;color:var(--blu);margin:.75rem 0 2rem">{album.data.titolo}</h1>

  {album.data.foto.length === 0
    ? <p style="color:var(--testo2)">Nessuna foto in questo album.</p>
    : <div class="galleria-grid" style="grid-template-columns:repeat(auto-fill,minmax(200px,1fr))">
        {album.data.foto.map((src, i) => (
          <a class="galleria-item glightbox" href={src} data-gallery="album" data-title={`${album.data.titolo} – ${i + 1}`}>
            <img src={src} alt={`Foto ${i + 1}`} loading="lazy"/>
          </a>
        ))}
      </div>
  }
</div>

<Footer />

<script>
  import GLightbox from 'glightbox';
  document.addEventListener('DOMContentLoaded', () => {
    GLightbox({ selector: '.glightbox', touchNavigation: true, loop: true });
  });
</script>

</Layout>
