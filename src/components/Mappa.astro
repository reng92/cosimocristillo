---
const pins = [
  { lat: 41.0528, lng: 14.3043, icon: '🏛️', label: 'Piazza Rimembranza', desc: 'Centro del paese – circolo anziani e attività culturali' },
  { lat: 41.0523, lng: 14.3037, icon: '⚙️', label: 'Municipio', desc: 'Sede comunale – sportelli digitali, Punto Donna, Sportello Disabili' },
  { lat: 41.0587, lng: 14.2803, icon: '🏫', label: 'Scuola Via Principe di Piemonte', desc: 'Operazione verità – cronoprogramma dei lavori pubblico' },
  { lat: 41.0661, lng: 14.3201, icon: '🏭', label: 'Zona Industriale', desc: 'Potenziamento servizi, sicurezza e viabilità' },
  { lat: 41.0612, lng: 14.2958, icon: '🏗️', label: 'Musicile', desc: 'Scuola primaria, bocciodromo, spazio anziani' },
  { lat: 41.0604, lng: 14.2793, icon: '🌿', label: 'Piazza Berlinguer', desc: 'Riapertura e restituzione alla comunità' },
  { lat: 41.0634, lng: 14.3079, icon: '🎭', label: 'Teatro Comunale', desc: 'Completamento e riapertura: centro culturale di Portico' },
];
---

<div id="mappa-leaflet"></div>
<div class="mappa-legenda">
  {pins.map(p => (
    <span class="mappa-pin-label"><span>{p.icon}</span>{p.label}</span>
  ))}
</div>

<script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js" is:inline></script>
<script define:vars={{ pins }}>
document.addEventListener('DOMContentLoaded', () => {
  const map = L.map('mappa-leaflet').setView([41.059, 14.299], 13);

  L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
    attribution: '© <a href="https://www.openstreetmap.org/copyright">OpenStreetMap</a>',
    maxZoom: 19,
  }).addTo(map);

  pins.forEach(p => {
    const icon = L.divIcon({
      html: `<div style="font-size:1.6rem;line-height:1;filter:drop-shadow(0 2px 4px rgba(0,0,0,.4))">${p.icon}</div>`,
      className: '',
      iconSize: [32, 32],
      iconAnchor: [16, 32],
    });
    L.marker([p.lat, p.lng], { icon })
      .addTo(map)
      .bindPopup(`<strong style="color:#0d3580">${p.label}</strong><br><span style="font-size:.82rem">${p.desc}</span>`);
  });
});
</script>
